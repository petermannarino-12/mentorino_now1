# Client-side (Vite reads at build time — must be in Netlify dashboard too)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# Server-side (Netlify Functions only — NOT exposed to client)
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
SENDER_EMAIL=admissions@mentorino.me
ADMIN_EMAIL=admissions@mentorino.me
GEMINI_API_KEY=

# Production URL
URL=https://mentorino.me
SITE_URL=https://mentorino.me

# Prisma connects directly to Supabase Postgres (session pooler, port 5432)
DATABASE_URL=postgresql://
